<div class="maintenance-page">
  <div class="maintenance-shell">

    <div class="maintenance-icon">⚙️</div>

    <h1 class="maintenance-title">
      This page is under maintenance
    </h1>

    <p class="maintenance-sub">
      This page under <%= ENV['WEBSITE_NAME'] %> is temporarily offline while we update and improve the platform.<br>
      Everything will be back shortly — thank you for your patience.
    </p>

    <a href="/" class="maintenance-btn">Try Again</a>

    <p class="maintenance-note">
      If this message continues, please contact support at <strong><%= ENV['WEBSITE_EMAIL'] %></strong>.
    </p>
  </div>
</div>

<style>
  .maintenance-page {
    --accent: #4f46e5;
    --accent-dark: #312e81;
    --text-main: #111827;
    --text-sub: #4b5563;

    min-height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 32px 16px;
    background: radial-gradient(circle at top, #eef2ff 0%, #f9fafb 55%, #f3f4f6 100%);
    font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .maintenance-shell {
    max-width: 600px;
    text-align: center;
  }

  .maintenance-icon {
    font-size: 58px;
    margin-bottom: 12px;
    animation: spin 3s linear infinite;
  }

  @keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .maintenance-title {
    font-size: 32px;
    font-weight: 700;
    color: var(--text-main);
    margin-bottom: 10px;
  }

  .maintenance-sub {
    font-size: 16px;
    color: var(--text-sub);
    line-height: 1.6;
    margin-bottom: 24px;
  }

  .maintenance-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 22px;
    border-radius: 999px;
    background: linear-gradient(to right, var(--accent), #6366f1);
    color: #ffffff;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    box-shadow: 0 10px 26px rgba(79, 70, 229, 0.3);
    transition: 0.2s;
  }

  .maintenance-btn:hover {
    box-shadow: 0 14px 34px rgba(79, 70, 229, 0.45);
    transform: translateY(-2px);
  }

  .maintenance-note {
    margin-top: 18px;
    font-size: 13px;
    color: #6b7280;
  }
</style>
