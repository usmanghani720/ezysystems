
<head>
  <title><%= ENV['WEBSITE_NAME'] %> – Expenses</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    /* ========= <%= ENV['WEBSITE_NAME'] %> Expenses Page ========= */

    .exp-page {
      --bg: #f5f5fb;
      --bg-card: #ffffff;
      --text-main: #111827;
      --text-sub: #4b5563;
      --muted: #6b7280;
      --border-soft: #e5e7eb;
      --accent: #4f46e5;
      --accent-soft: #eef2ff;
      --accent-dark: #312e81;
      --accent-green: #16a34a;
      --shadow-soft: 0 18px 45px rgba(15, 23, 42, 0.12);
      --radius-lg: 18px;
      --radius-md: 14px;
      --radius-pill: 999px;

      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      color: var(--text-main);
      background: radial-gradient(circle at top left, #eef2ff 0, #f9fafb 40%, #f3f4f6 100%);
      padding: 40px 16px 72px;
    }

    .exp-page * {
      box-sizing: border-box;
    }

    .exp-shell {
      max-width: 1120px;
      margin: 0 auto;
    }

    /* ---------- Hero ---------- */

    .exp-hero {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      gap: 40px;
      align-items: center;
      margin-top: 32px;
      margin-bottom: 56px;
    }

    @media (max-width: 900px) {
      .exp-hero {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .exp-kicker {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 6px 12px;
      border-radius: var(--radius-pill);
      border: 1px solid rgba(148, 163, 184, 0.5);
      background: linear-gradient(to right, #ffffff, #eef2ff);
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.09em;
      color: var(--muted);
      margin-bottom: 16px;
    }

    .exp-kicker-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: radial-gradient(circle at center, #a5b4fc 0, #4f46e5 55%, #1e1b4b 100%);
      box-shadow: 0 0 10px rgba(129, 140, 248, 0.9);
    }

    .exp-title {
      font-size: clamp(32px, 4.2vw, 40px);
      font-weight: 700;
      letter-spacing: -0.035em;
      margin-bottom: 10px;
    }

    .exp-title span {
      color: var(--accent-dark);
    }

    .exp-sub {
      font-size: 16px;
      color: var(--text-sub);
      max-width: 520px;
      margin-bottom: 20px;
    }

    .exp-hero-note {
      font-size: 13px;
      color: var(--muted);
      margin-bottom: 24px;
    }

    .exp-cta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 20px;
    }

    .btn-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 10px 20px;
      border-radius: var(--radius-pill);
      font-size: 14px;
      font-weight: 500;
      text-decoration: none;
      cursor: pointer;
      border: 1px solid transparent;
      transition: transform 0.12s ease, box-shadow 0.15s ease, background 0.15s ease, border-color 0.15s ease;
      white-space: nowrap;
    }

    .btn-primary {
      background: linear-gradient(to right, var(--accent), #6366f1);
      color: #ffffff;
      box-shadow: 0 12px 30px rgba(79, 70, 229, 0.4);
      border-color: rgba(191, 219, 254, 0.9);
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 18px 38px rgba(79, 70, 229, 0.6);
    }

    .btn-secondary {
      background: #ffffff;
      color: var(--accent-dark);
      border-color: rgba(148, 163, 184, 0.6);
    }

    .btn-secondary:hover {
      background: #f3f4ff;
      transform: translateY(-1px);
    }

    .exp-hero-foot {
      font-size: 12px;
      color: var(--muted);
    }

    .exp-hero-foot span {
      font-weight: 500;
      color: var(--accent-dark);
    }

    .exp-hero-media {
      position: relative;
    }

    .exp-hero-card {
      border-radius: 24px;
      background: radial-gradient(circle at top left, rgba(79, 70, 229, 0.25), rgba(15, 23, 42, 0.98));
      padding: 18px 18px 20px;
      color: #e5e7eb;
      box-shadow: var(--shadow-soft);
      font-size: 12px;
    }

    .exp-hero-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
      font-size: 11px;
    }

    .exp-hero-chip {
      padding: 4px 8px;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.7);
      border: 1px solid rgba(148, 163, 184, 0.5);
    }

    .exp-hero-status {
      padding: 4px 8px;
      border-radius: 999px;
      background: rgba(34, 197, 94, 0.18);
      border: 1px solid rgba(74, 222, 128, 0.7);
      color: #bbf7d0;
      font-weight: 500;
    }

    .exp-hero-topline {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      font-size: 11px;
      margin-bottom: 8px;
    }

    .exp-hero-topline span {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      color: #e5e7eb;
    }

    .exp-hero-topline strong {
      font-size: 13px;
    }

    .exp-hero-items {
      background: rgba(15, 23, 42, 0.85);
      border-radius: 12px;
      padding: 10px 10px 8px;
      margin-bottom: 8px;
    }

    .exp-hero-items-header,
    .exp-hero-items-row {
      display: grid;
      grid-template-columns: 1.4fr 1fr 0.9fr;
      gap: 8px;
      font-size: 11px;
    }

    .exp-hero-items-header {
      color: #9ca3af;
      margin-bottom: 4px;
    }

    .exp-hero-items-row {
      margin-bottom: 2px;
    }

    .exp-hero-items-row strong {
      font-weight: 500;
    }

    .exp-hero-summary {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      font-size: 11px;
      color: #e5e7eb;
      margin-bottom: 10px;
    }

    .exp-hero-summary dl {
      margin: 0;
    }

    .exp-hero-summary dt {
      color: #9ca3af;
    }

    .exp-hero-summary dd {
      margin: 0;
      font-weight: 600;
    }

    .exp-hero-meta {
      font-size: 11px;
      color: #9ca3af;
      margin-bottom: 6px;
    }

    .exp-hero-meta code {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono",
        "Courier New", monospace;
      font-size: 11px;
      background: rgba(15, 23, 42, 0.85);
      padding: 2px 5px;
      border-radius: 6px;
      color: #e0e7ff;
    }

    .exp-hero-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 10px;
      color: #9ca3af;
    }

    .exp-hero-footer span {
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }

    .exp-hero-footer-dot {
      width: 6px;
      height: 6px;
      border-radius: 999px;
      background: #22c55e;
      box-shadow: 0 0 6px rgba(34, 197, 94, 0.9);
    }

    .exp-hero-shadow {
      position: absolute;
      inset: 18px;
      border-radius: 24px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      pointer-events: none;
    }

    /* ---------- Intro ---------- */

    .exp-intro {
      max-width: 720px;
      margin-bottom: 40px;
    }

    .exp-intro h2 {
      font-size: 22px;
      margin-bottom: 8px;
    }

    .exp-intro p {
      font-size: 15px;
      color: var(--text-sub);
      margin-bottom: 10px;
    }

    .exp-intro strong {
      color: var(--accent-dark);
      font-weight: 600;
    }

    /* ---------- Section headings ---------- */

    .exp-section-heading {
      margin: 40px 0 16px;
    }

    .exp-section-kicker {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--muted);
      margin-bottom: 4px;
    }

    .exp-section-title {
      font-size: 20px;
      margin-bottom: 6px;
    }

    .exp-section-sub {
      font-size: 14px;
      color: var(--text-sub);
      max-width: 620px;
    }

    /* ---------- Dual feature cards ---------- */

    .exp-feature-group {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px;
      margin-bottom: 40px;
    }

    @media (max-width: 900px) {
      .exp-feature-group {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .exp-feature-card {
      background: var(--bg-card);
      border-radius: var(--radius-md);
      border: 1px solid var(--border-soft);
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.03);
      padding: 18px 18px 20px;
      font-size: 13px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .exp-feature-label {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--muted);
      margin-bottom: 2px;
    }

    .exp-feature-title {
      font-size: 15px;
      font-weight: 600;
    }

    .exp-feature-text {
      font-size: 13px;
      color: var(--text-sub);
    }

    .exp-feature-list {
      font-size: 13px;
      color: var(--text-sub);
      padding-left: 18px;
      margin-top: 4px;
    }

    .exp-feature-list li {
      margin-bottom: 3px;
    }

    .exp-feature-note {
      font-size: 12px;
      color: var(--muted);
      margin-top: 2px;
    }

    /* ---------- Testimonials ---------- */

    .exp-testimonial-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
      margin: 24px 0 52px;
    }

    @media (max-width: 960px) {
      .exp-testimonial-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 700px) {
      .exp-testimonial-grid {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .exp-testimonial-card {
      background: #0b1020;
      border-radius: var(--radius-md);
      padding: 18px 18px 16px;
      color: #e5e7eb;
      position: relative;
      overflow: hidden;
      box-shadow: 0 16px 40px rgba(15, 23, 42, 0.6);
    }

    .exp-testimonial-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at top left, rgba(79, 70, 229, 0.5), transparent 55%);
      opacity: 0.9;
      pointer-events: none;
    }

    .exp-testimonial-logo {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: #9ca3af;
      margin-bottom: 6px;
      position: relative;
      z-index: 1;
    }

    .exp-testimonial-heading {
      font-size: 15px;
      font-weight: 600;
      margin-bottom: 6px;
      position: relative;
      z-index: 1;
    }

    .exp-testimonial-text {
      font-size: 13px;
      color: #cbd5f5;
      margin-bottom: 10px;
      position: relative;
      z-index: 1;
    }

    .exp-testimonial-person {
      font-size: 12px;
      color: #9ca3af;
      position: relative;
      z-index: 1;
    }

    .exp-testimonial-person strong {
      display: block;
      color: #e5e7eb;
    }

    /* ---------- Articles ---------- */

    .exp-articles-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 20px;
      margin: 24px 0 40px;
    }

    @media (max-width: 960px) {
      .exp-articles-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
    @media (max-width: 700px) {
      .exp-articles-grid {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .exp-article-card {
      background: var(--bg-card);
      border-radius: 14px;
      border: 1px solid var(--border-soft);
      padding: 14px 14px 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      font-size: 13px;
      box-shadow: 0 8px 20px rgba(15, 23, 42, 0.04);
    }

    .exp-article-tag {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--muted);
    }

    .exp-article-title {
      font-weight: 600;
      font-size: 14px;
    }

    .exp-article-text {
      color: var(--text-sub);
    }

    .exp-article-meta {
      font-size: 11px;
      color: var(--muted);
      margin-top: 2px;
    }

    .exp-article-link {
      font-size: 12px;
      color: var(--accent-dark);
      text-decoration: none;
      font-weight: 500;
      margin-top: 4px;
    }

    .exp-article-link:hover {
      text-decoration: underline;
    }

    /* ---------- Newsletter ---------- */

    .exp-newsletter {
      margin-top: 16px;
      padding: 18px 20px;
      border-radius: 16px;
      background: linear-gradient(to right, #111827, #020617);
      color: #e5e7eb;
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      gap: 18px;
      align-items: center;
    }

    @media (max-width: 720px) {
      .exp-newsletter {
        grid-template-columns: minmax(0, 1fr);
      }
    }

    .exp-newsletter h3 {
      font-size: 16px;
      margin-bottom: 4px;
    }

    .exp-newsletter p {
      font-size: 13px;
      color: #9ca3af;
    }

    .exp-newsletter-form {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      justify-content: flex-end;
    }

    .exp-newsletter-input {
      flex: 1 1 180px;
      min-width: 0;
      border-radius: var(--radius-pill);
      border: 1px solid rgba(148, 163, 184, 0.7);
      padding: 8px 12px;
      font-size: 13px;
      background: rgba(15, 23, 42, 0.8);
      color: #e5e7eb;
      outline: none;
    }

    .exp-newsletter-input::placeholder {
      color: #6b7280;
    }

    .exp-newsletter-btn {
      padding: 8px 16px;
      border-radius: var(--radius-pill);
      border: none;
      background: linear-gradient(to right, var(--accent), #6366f1);
      color: #f9fafb;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      box-shadow: 0 10px 26px rgba(79, 70, 229, 0.5);
      white-space: nowrap;
    }

    .exp-newsletter-btn:hover {
      transform: translateY(-1px);
    }
  </style>
</head>

<%= render partial: "layouts/header" %>
<div class="exp-page" id="expenses">
  <div class="exp-shell">

    <!-- HERO -->
    <section class="exp-hero">
      <div>
        <h1 class="exp-title">
          Keep every business cost <span>logged, organised and tax-ready.</span>
        </h1>
        <p class="exp-sub">
          <%= ENV['WEBSITE_NAME'] %> gives you simple tools to record fuel, supplies, subscriptions and other business
          expenses in one place, so your accounts stay accurate and ready for tax season.
        </p>
        <p class="exp-hero-note">
          Capture receipts on the go, assign tax rates, link expenses to suppliers and keep your books
          clean — without spreadsheets and shoeboxes full of paper.
        </p>

        <div class="exp-cta-row">
          <a href="/users/sign_up" class="btn-pill btn-primary">Start a free trial</a>
          <a href="/pricing" class="btn-pill btn-secondary">See pricing</a>
        </div>
        <p class="exp-hero-foot">
          <span>Income, invoices and expenses all in <%= ENV['WEBSITE_NAME'] %>.</span> One system for a clearer picture of profit.
        </p>
      </div>

      <!-- Right: expenses mockup -->
      <div class="exp-hero-media">
        <div class="exp-hero-card">
          <div class="exp-hero-header">
            <div class="exp-hero-chip"><%= ENV['WEBSITE_NAME'] %> · Expenses</div>
            <div class="exp-hero-status">Reconciled this month</div>
          </div>

          <div class="exp-hero-topline">
            <span>Period: <strong>Mar 2025</strong></span>
            <span>Total expenses: <strong>$4,320.45</strong></span>
          </div>

          <div class="exp-hero-items">
            <div class="exp-hero-items-header">
              <span>Category</span>
              <span>Supplier</span>
              <span>Amount</span>
            </div>
            <div class="exp-hero-items-row">
              <span><strong>Fuel – Route vehicles</strong></span>
              <span>City Fuel Station</span>
              <span>$1,145.30</span>
            </div>
            <div class="exp-hero-items-row">
              <span>Cleaning supplies &amp; materials</span>
              <span>ClearChem Supplies</span>
              <span>$980.15</span>
            </div>
            <div class="exp-hero-items-row">
              <span>Software &amp; subscriptions</span>
              <span>Ezysystem / other apps</span>
              <span>$465.00</span>
            </div>
          </div>

          <div class="exp-hero-summary">
            <dl>
              <dt>Tax reclaimable</dt>
              <dd>$720.88</dd>
            </dl>
            <dl>
              <dt>Net cost</dt>
              <dd>$3,599.57</dd>
            </dl>
          </div>

          <div class="exp-hero-meta">
            View: <code>Expenses · This month · By category</code>
          </div>

          <div class="exp-hero-footer">
            <span>
              <span class="exp-hero-footer-dot"></span>
              Receipts stored &amp; searchable
            </span>
            <span>Export-ready for your accountant</span>
          </div>
        </div>
        <div class="exp-hero-shadow"></div>
      </div>
    </section>

    <!-- INTRO -->
    <section class="exp-intro">
      <h2>Know where your money is going, every day.</h2>
      <p>
        It’s easy for small purchases to add up when you’re running a busy service business. Fuel,
        equipment, licences, software, materials — if they’re not logged properly, you lose visibility
        on profit and make tax time harder than it needs to be.
      </p>
      <p>
        <%= ENV['WEBSITE_NAME'] %> helps you <strong>capture expenses as they happen</strong>, link them to suppliers and
        categories, and keep everything together with your jobs, invoices and payments.
      </p>
      <p>
        That means cleaner records, better decisions and fewer surprises when your accountant asks for
        the numbers.
      </p>
    </section>

    <!-- LOG EXPENSES / SUPPLIERS SECTION TITLE -->
    <section>
      <div class="exp-section-heading">
        <p class="exp-section-kicker">Expense Management</p>
        <h2 class="exp-section-title">Track everyday costs without spreadsheets or guesswork.</h2>
        <p class="exp-section-sub">
          Log day-to-day business expenses, keep supplier details organised and stay ready for tax and
          year-end reporting.
        </p>
      </div>

      <div class="exp-feature-group">
        <!-- Record Expenses -->
        <article class="exp-feature-card">
          <p class="exp-feature-label">Record Expenses</p>
          <h3 class="exp-feature-title">Capture daily costs from your phone or desktop</h3>
          <p class="exp-feature-text">
            Add business expenses directly into <%= ENV['WEBSITE_NAME'] %> — fuel, equipment, tools, materials, office
            supplies, subscriptions and more — and assign them to the correct category in a few taps.
          </p>
          <ul class="exp-feature-list">
            <li>Enter amounts, dates and payment methods in seconds</li>
            <li>Upload photos of receipts so nothing gets lost</li>
            <li>Apply the right tax rate and add notes for context</li>
          </ul>
          <p class="exp-feature-note">
            Ideal for busy teams who want tidy records without extra admin time.
          </p>
        </article>

        <!-- Manage Suppliers -->
        <article class="exp-feature-card">
          <p class="exp-feature-label">Manage Suppliers</p>
          <h3 class="exp-feature-title">Keep supplier information separate from customers</h3>
          <p class="exp-feature-text">
            Store supplier contact details, notes and purchase history in one place. Link expenses
            directly to the right supplier to keep your accounts clear and transparent.
          </p>
          <ul class="exp-feature-list">
            <li>Search, filter and organise suppliers by type or category</li>
            <li>See which suppliers you’re spending the most with</li>
            <li>Keep supplier records away from your customer list to avoid mix-ups</li>
          </ul>
          <p class="exp-feature-note">
            Helpful for reconciling statements and negotiating better pricing.
          </p>
        </article>
      </div>
    </section>

    <!-- EXTRA FEATURES: CATEGORIES / TAX / REPORTS -->
    <section>
      <div class="exp-section-heading">
        <p class="exp-section-kicker">Control &amp; clarity</p>
        <h2 class="exp-section-title">Categories, tax and reporting that work together.</h2>
        <p class="exp-section-sub">
          Organise your costs by category, assign tax rates correctly and generate clear summaries
          whenever you need them.
        </p>
      </div>

      <div class="exp-feature-group">
        <!-- Categories & Tax -->
        <article class="exp-feature-card">
          <p class="exp-feature-label">Categories &amp; Tax</p>
          <h3 class="exp-feature-title">Make expenses meaningful at tax time</h3>
          <p class="exp-feature-text">
            Create categories that mirror how you and your accountant think about costs — fuel, vehicles,
            equipment, marketing, software, etc. Apply tax rules so reclaimable amounts are obvious.
          </p>
          <ul class="exp-feature-list">
            <li>Customisable categories that match your business</li>
            <li>Tax-aware entries so reclaimable tax is easy to report</li>
            <li>Tag expenses to routes, teams or projects for extra clarity</li>
          </ul>
          <p class="exp-feature-note">
            Set it up once and apply the right category and tax rate every time.
          </p>
        </article>

        <!-- Reporting & Export -->
        <article class="exp-feature-card">
          <p class="exp-feature-label">Reporting &amp; Export</p>
          <h3 class="exp-feature-title">See costs by month, supplier or category in a click</h3>
          <p class="exp-feature-text">
            Use built-in views to review spending over time and identify where money is going. When
            it’s time to share data, export clean reports for your accountant or accounting software.
          </p>
          <ul class="exp-feature-list">
            <li>Filter by date range, category, supplier or status</li>
            <li>Compare expense totals against income in <%= ENV['WEBSITE_NAME'] %></li>
            <li>Export CSV data for deeper analysis or bookkeeping tools</li>
          </ul>
          <p class="exp-feature-note">
            Helpful for budgeting, forecasting and understanding real profitability.
          </p>
        </article>
      </div>
    </section>

    <!-- TESTIMONIALS -->
    <section>
      <div class="exp-section-heading">
