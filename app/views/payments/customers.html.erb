
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.4.1/css/responsive.dataTables.min.css">



<div class="content-wrapper tables-data-page">
  <!-- Content Header (Page header) -->
  <section class="content-header">
    <h1>
    Customers
    </h1>
    <ol class="breadcrumb">
      <li><%= link_to authenticated_root_path do %><i class="fa fa-dashboard"></i> Home<% end %></li>
    </ol>
  </section>

  <section>
    <div class="row">
      <!-- left column -->
      <div class="col-md-12">
        <div class="box box-primary" data-aos="fade-up">
          <div class="box-header with-border" style="text-align: right;">
            <%= link_to 'New', new_customer_path,:class=>"btn btn-block btn-info",:style=>"display:inline;" %>
          </div>

        </div>
      </div>
    </div>
  </section>


  <!-- Main content -->
  <section class="content">
    <div class="row">
      <div class="col-xs-12">
        <%= render "/layouts/alerts" %>
        <div class="box">
          <div class="box-body">
            <% if current_user.try(:unique_code).present? %>
              <p id="customer-link"><%= ENV['WEBSITE_URL'] + "/users/sign_up?id=" + current_user.try(:unique_code) %></p>
            <% end %>
            <button class="copy_btn btn btn-block btn-info">Copy Link</button>
            <br />
            <table id="customers" class="table table-bordered table-striped" style="width: 100 !important;">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Created</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>ID</th>
                  <th>Payment Method</th>
                  <th></th>
                  <th></th>
                  <th></th>
                  <th>Url</th>
                </tr>
              </thead>
              <tbody>
                <% @customers.each do |customer| %>
                  <tr>
                    <td><%= customer.name %></td>
                    <td><%= customer.created_at.strftime("%a, %d %b %Y") %></td>
                    <td><%= customer.email %></td>
                    <td><%= customer.phone %></td>
                    <td><%= customer.customer_id %> </td>
                    <td>
                      <% if !customer.payment_method.blank? %> 
                        <p><%= customer.brand %></p>
                        <p><%= customer.last4 %></p>
                      <% else %>
                        <p>Not Available</p>
                      <% end %>
                    </td>
                    <td>
                      <% if !customer.payment_method.blank? %> 
                        <%= link_to 'Create Payment', create_payment_path(id: customer.id),:class=>"btn btn-block btn-info",:style=>"display:inline;" %>
                      <% end %>
                    </td>
                    <td>
                      <%= link_to(ActionController::Base.helpers.image_tag("destroy.png",:class=>"index_img",:title=>"Destroy"), remove_customer_path(customer), method: :post, data: { confirm: 'Are you sure?' }, :class=>"btn bg-maroon m-r-5") %>
                    </td>
                    <td>
                      <p><%= "#{customer.last_payment_id}" %></p>
                      <p><%= "#{customer.last_payment_amount} #{customer.last_payment_currency}" %></p>
                      <% if customer.last_payment_date.present? %>
                        <p><%= "#{customer.last_payment_date.to_date.strftime("%a, %d %b %Y")}" %></p>
                      <% end %>
                    </td>
                    <td style="word-break: break-all;white-space: normal;">
                      <% if customer.customer_card_url.present? %>
                        <%= "#{ENV['WEBSITE_URL']}" + "/checkout/" + customer.try(:customer_id) %>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              </tbody>

            </table>
          </div><!-- /.box-body -->
        </div><!-- /.box -->
      </div><!-- /.col -->
    </div><!-- /.row -->
  </section><!-- /.content -->
</div><!-- /.content-wrapper -->


<script>
  $("#customers").DataTable({
    responsive: true,
    "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
    "aaSorting": [[1, "asc"]],
  });

</script>

  <script>
  document.addEventListener("DOMContentLoaded", function () {
    // Check if the page has already been reloaded
    if (!sessionStorage.getItem('reloaded')) {
      sessionStorage.setItem('reloaded', 'true'); // Mark as reloaded
      location.reload(); // Reload the page
    } else {
      sessionStorage.removeItem('reloaded'); // Remove the flag after reloading once
    }
  })
$(document).on('click', '.copy_btn', function (e) {
    const copyTxtField = document.getElementById("customer-link");
    navigator.clipboard.writeText(copyTxtField.textContent)
    .then(() => {
      console.log(copyTxtField.textContent);
    })
    .catch(err => {
      console.error("Failed to copy: ", err);
    });
})
</script>


