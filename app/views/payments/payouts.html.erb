<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.4.1/css/responsive.dataTables.min.css">

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.4.1/js/dataTables.responsive.min.js"></script>


<div class="content-wrapper tables-data-page">
  <!-- Content Header (Page header) -->
  <section class="content-header">
    <h1>
      Payouts
    </h1>
    <h5>Available Balance  <%= @available_balance %> <%= @currency %></h5>
    <h5>Pending Balance  <%= @pending_balance %> <%= @currency %></h5>
    <ol class="breadcrumb">
      <li><%= link_to root_path do %><i class="fa fa-dashboard"></i> Home<% end %></li>
    </ol>
  </section>

  <section>
    <div class="row">
      <!-- left column -->
      <div class="col-md-12">
        <div class="box box-primary" data-aos="fade-up">
          <div class="box-header with-border" style="text-align: right;">
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Main content -->
  <section class="content">
    <div class="row">
      <div class="col-xs-12">
        <%= render "/layouts/alerts" %>
        <div class="box">
          <%#= link_to "Create Payout for all the available balance", create_payout_path, method: :post, data: { confirm: 'Are you sure?' },:class=>"btn btn-block btn-info" %>
          <br/>
          <%= link_to "Create Payout for entered amount", payout_path,:class=>"btn btn-block btn-info" %>
          <div class="box-body">
            <table id="payouts" class="table table-bordered table-striped">
              <thead>
                <tr>
                  <th>Amount</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% @payouts.each do |payout| %>
                  <tr>
                    <td><%= ((payout.amount)) %> <%= @currency %></td>
                    <td><%= payout.created_at.strftime("%A, %d %B %Y") %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div><!-- /.box-body -->
        </div><!-- /.box -->
      </div><!-- /.col -->
    </div><!-- /.row -->
  </section><!-- /.content -->
</div><!-- /.content-wrapper -->


<script>
  $("#payouts").DataTable({
    responsive: true,
    "lengthMenu": [[10, 25, 50, -1], [10, 25, 50, "All"]],
    "aaSorting": [[1, "asc"]],
  });
</script>

