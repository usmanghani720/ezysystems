

<link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/datatables/1.10.21/css/dataTables.bootstrap.min.css">
<script src="https://cdn.datatables.net/1.10.25/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/1.10.25/js/dataTables.bootstrap.min.js"></script>


<% if params[:cvc].blank? %>
<div class="content-wrapper tables-data-page">
  <!-- Content Header (Page header) -->
  <section class="content-header">
    <h1>
      Create Payment
    </h1>
    <ol class="breadcrumb">
      <li><%= link_to authenticated_root_path do %><i class="fa fa-dashboard"></i> Home<% end %></li>
    </ol>
  </section>

    <section>
      <div class="row">
        <!-- left column -->
        <div class="col-md-12">
          <div class="box box-primary">
            <div class="box-header with-border">
              <%= form_with url: create_payment_path(@customer), method: :post do %>
                  <input id="amount" name="amount" class="form-control" style="width: 100%" placeholder="Enter amount in usd" required/>
                  <br/>
                  <input id="shipping"
                    class="form-control"
                    style="width: 100%"
                    placeholder="Shipping Address"
                  />
                  <br/>
                  <textarea id="description" name="description" class="form-control" style="width: 100%" placeholder="Description" rows="5"></textarea>
                  <input type="hidden" id="shipping_line1" name="shipping_line1">
                  <input type="hidden" id="shipping_city" name="shipping_city">
                  <input type="hidden" id="shipping_state" name="shipping_state">
                  <input type="hidden" id="shipping_postal_code" name="shipping_postal_code">
                  <input type="hidden" id="shipping_country" name="shipping_country">
                  <input type="hidden" id="shipping_name" name="shipping_name">
                  <%= submit_tag 'Make Payment',:class=>"btn btn-block btn-info",:style=>"display:inline;" %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
<% else %>
<div class="content-wrapper tables-data-page">
  <section class="content-header">
    <h1>Create Payment for <%= @customer.name %></h1>
    <ol class="breadcrumb">
      <li><%= link_to authenticated_root_path do %>
        <i class="fa fa-dashboard"></i> Home
      <% end %></li>
    </ol>
  </section>

  <section>
    <div class="row">
      <div class="col-md-12">
        <div class="box box-primary">
          <div class="box-header with-border">
            <p>
              Saved card:
              <strong><%= @customer.brand %></strong>
              ending in <strong><%= @customer.last4 %></strong>
            </p>

            <div id="messages" style="color:red;"></div>

            <div class="form-group">
              <input id="amount"
                     class="form-control"
                     style="width: 100%"
                     placeholder="Enter amount in USD"
                     required />
            </div>

            <div class="form-group">
              <div id="card-cvc-element"
                   class="form-control"
                   style="width:100%; padding:8px;"></div>
            </div>

            <div class="form-group">
              <input id="shipping"
                     class="form-control"
                     style="width: 100%"
                     placeholder="Shipping Address"
              />
            </div>

            <div class="form-group">
              <textarea id="description"
                        class="form-control"
                        style="width: 100%"
                        placeholder="Description"
                        rows="5"></textarea>
            </div>
            <input type="hidden" id="shipping" name="shipping">
            <input type="hidden" id="shipping_line1" name="shipping_line1">
            <input type="hidden" id="shipping_city" name="shipping_city">
            <input type="hidden" id="shipping_state" name="shipping_state">
            <input type="hidden" id="shipping_postal_code" name="shipping_postal_code">
            <input type="hidden" id="shipping_country" name="shipping_country">

            <button id="charge-button"
                    class="btn btn-block btn-info"
                    type="button">
              Make Payment
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>
<% end %>



<script>
  // Check if the page has already been reloaded
  if (!sessionStorage.getItem('reloaded')) {
    sessionStorage.setItem('reloaded', 'true'); // Mark as reloaded
    location.reload(); // Reload the page
  } else {
    sessionStorage.removeItem('reloaded'); // Remove the flag after reloading once
  }
</script>

<script>
  // 1) Stripe setup in CONNECTED ACCOUNT context
  const stripe = Stripe(
    "<%= ENV['STRIPE_PUBLISHABLE_KEY'] %>",
    { stripeAccount: "<%= current_user.stripe_user_id %>" }
  );
  const elements = stripe.elements();

  // Mount CVC-only element into the div
  const cardCvcElement = elements.create("cardCvc");
  cardCvcElement.mount("#card-cvc-element");

  const chargeButton = document.getElementById("charge-button");
  const messages     = document.getElementById("messages");

  function showMessage(msg) {
    messages.textContent = msg || "";
  }

  // CSRF token for Rails
  const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;

  chargeButton.addEventListener("click", async function (e) {
    e.preventDefault();
    showMessage("");

    const amount       = document.getElementById("amount").value;
    const description  = document.getElementById("description").value || "";
    const shipping  = document.getElementById("shipping").value || "";

    if (!amount || parseFloat(amount) <= 0) {
      showMessage("Please enter a valid amount.");
      return;
    }

    chargeButton.disabled  = true;
    chargeButton.textContent = "Processing...";

    try {
      const piResp = await fetch("<%= saved_card_intents_path %>", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-CSRF-Token": csrfToken
        },
        body: JSON.stringify({
          customer_id: "<%= @customer.id %>",
          amount:      amount,
          shipping_name: document.getElementById('shipping').value,
          shipping_line1: document.getElementById("shipping_line1").value,
          shipping_city: document.getElementById("shipping_city").value,
          shipping_state: document.getElementById("shipping_state").value,
          shipping_postal_code: document.getElementById("shipping_postal_code").value,
          shipping_country: document.getElementById("shipping_country").value
        })
      });

      const piData = await piResp.json();
      if (!piResp.ok) {
        showMessage(piData.error || "Error creating payment.");
        chargeButton.disabled  = false;
        chargeButton.textContent = "Make Payment";
        return;
      }

      const clientSecret    = piData.client_secret;
      const paymentMethodId = "<%= @customer.payment_method %>"; // pm_xxx stored on customer

      //
      // 3) Confirm the PaymentIntent with the SAVED CARD + recollected CVC
      //
      const result = await stripe.confirmCardPayment(clientSecret, {
        payment_method: paymentMethodId,
        payment_method_options: {
          card: {
            cvc: cardCvcElement
          }
        }
      });

      if (result.error) {
        // Stripe rejected payment (CVC failure, auth failure, etc.)
        showMessage(result.error.message);
        chargeButton.disabled  = false;
        chargeButton.textContent = "Make Payment";
        return;
      }

      if (!result.paymentIntent || result.paymentIntent.status !== "succeeded") {
        showMessage(
          "Payment did not succeed. Status: " +
          (result.paymentIntent && result.paymentIntent.status)
        );
        chargeButton.disabled  = false;
        chargeButton.textContent = "Make Payment";
        return;
      }
      else{
        window.location = "<%= success_path(id: @customer.try(:id)) %>"
      }

    } catch (err) {
      console.error(err);
      showMessage("Unexpected error. Please try again.");
      chargeButton.disabled  = false;
      chargeButton.textContent = "Make Payment";
    }
  });
</script>


<script
  src="https://maps.googleapis.com/maps/api/js?key=<%= ENV['GOOGLE_MAPS_API_KEY']%>&libraries=places&callback=initAddressAutocomplete"
  defer>
</script>


<script>
  function initAddressAutocomplete() {
    const input = document.getElementById('shipping');
    if (!input) return;

    const autocomplete = new google.maps.places.Autocomplete(input, {
      types: ['address'],
    });

    autocomplete.addListener('place_changed', function () {
      const place = autocomplete.getPlace();
      if (!place.address_components) return;

      let street_number = "";
      let route         = "";
      let city          = "";
      let state         = "";
      let postal_code   = "";
      let country       = "";

      place.address_components.forEach(function (c) {
        const types = c.types;
        if (types.includes('street_number'))      street_number = c.long_name;
        if (types.includes('route'))              route         = c.long_name;
        if (types.includes('locality'))           city          = c.long_name;
        if (types.includes('administrative_area_level_1')) state = c.short_name;
        if (types.includes('postal_code'))        postal_code   = c.long_name;
        if (types.includes('country'))            country       = c.long_name; countryCode = c.short_name;
      });

      const line1 = [street_number, route].filter(Boolean).join(' ');

      document.getElementById("shipping_line1").value        = line1;
      document.getElementById("shipping_city").value         = city;
      document.getElementById("shipping_state").value        = state;
      document.getElementById("shipping_postal_code").value  = postal_code;
      document.getElementById("shipping_country").value      = countryCode; // use two-letter ISO for Stripe
      document.getElementById("shipping_name").value         = document.getElementById("shipping").value;
    });
  }

  // Turbo / normal navigation support
  document.addEventListener('turbo:load', initAddressAutocomplete);
  document.addEventListener('DOMContentLoaded', initAddressAutocomplete);
</script>





