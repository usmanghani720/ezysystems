<style>
/* --- Mega menu (desktop) --- */

/* parent wrapper for "Features" */
.nav-item.has-mega {
  position: relative;
}

/* dropdown panel (absolute under Features link) */
.nav-item.has-mega .mega-menu {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translate(-50%, 10px);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;

  /* FIX: give it a real width so it doesn't shrink */
  width: 1040px;
  max-width: calc(100vw - 48px);
}

/* show on hover / focus */
.nav-item.has-mega:hover .mega-menu,
.nav-item.has-mega:focus-within .mega-menu {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translate(-50%, 0);
}

/* inner layout */
.mega-inner {
  width: 100%;
  border-radius: 16px;
  background: #ffffff;
  box-shadow:
    0 18px 45px rgba(15, 23, 42, 0.18),
    0 0 0 1px rgba(226, 232, 240, 0.9);
  padding: 24px 32px 28px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 32px;
}

/* column styling */
.mega-column {
  min-width: 0;
}

.mega-column-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.mega-column-icon {
  width: 30px;
  height: 30px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #f3f4ff;
  font-size: 16px;
}

.mega-column-title {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #4b5563;
}

.mega-column-sub {
  font-size: 13px;
  color: #9ca3af;
}

/* links list */
.mega-links {
  list-style: none;
  padding: 0;
  margin: 6px 0 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.mega-links li a {
  display: block;
  padding: 8px 10px;
  border-radius: 10px;
  text-decoration: none;
  transition: background 0.12s ease, transform 0.12s ease;
}

.mega-link-title {
  display: block;
  font-size: 13px;
  font-weight: 500;
  color: #111827;
}

.mega-link-text {
  display: block;
  font-size: 12px;
  color: #6b7280;
}

.mega-links li a:hover {
  background: #f3f4ff;
  transform: translateX(2px);
}

/* optional chevron */
.mega-links li a::after {
  content: "›";
  float: right;
  font-size: 14px;
  color: #cbd5f5;
  margin-left: 6px;
  transition: transform 0.12s ease, color 0.12s ease;
}

.mega-links li a:hover::after {
  transform: translateX(2px);
  color: #4f46e5;
}

/* hide mega menu on small screens (mobile uses slide-out menu) */
@media (max-width: 1000px) {
  .nav-item.has-mega .mega-menu {
    display: none;
  }
}
</style>
