<header class="site-header">
  <div class="container header-grid">
    <div class="brand">
      <a href="/" data-turbo="false">
        <%= image_tag ENV['LOGO_NAME'], alt: ENV['WEBSITE_NAME'], class: "logo" %>
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button class="mobile-toggle" aria-label="Open menu" aria-controls="mobile-menu" aria-expanded="false">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <!-- Desktop nav -->
    <nav class="main-nav">
      <!-- Features + mega menu trigger -->
      <div class="nav-item has-mega">
        <a href="#features" class="nav-link">Features</a>

        <!-- Mega menu panel -->
        <div class="mega-menu">
          <div class="mega-inner">
            <!-- Column 1 -->
            <div class="mega-column">
              <div class="mega-column-header">
                <span class="mega-column-icon">👥</span>
                <div>
                  <p class="mega-column-title">Customer Services</p>
                  <p class="mega-column-sub">Delight customers at every step.</p>
                </div>
              </div>
              <ul class="mega-links">
                <li>
                  <a href="/custom_portal">
                    <span class="mega-link-title">Customer Portal</span>
                    <span class="mega-link-text">Let customers book, pay &amp; manage services.</span>
                  </a>
                </li>
                <li>
                  <a href="/customer_messaging">
                    <span class="mega-link-title">Customer Messaging</span>
                    <span class="mega-link-text">Clear communication, fewer missed jobs.</span>
                  </a>
                </li>
                <li>
                  <a href="/marketing_tools">
                    <span class="mega-link-title">Marketing Tools</span>
                    <span class="mega-link-text">Grow your business &amp; win more work.</span>
                  </a>
                </li>
                <li>
                  <a href="/marketing_messaging">
                    <span class="mega-link-title">Marketing Messaging</span>
                    <span class="mega-link-text">Stay in touch with your customers.</span>
                  </a>
                </li>
              </ul>
            </div>

            <!-- Column 2 -->
            <div class="mega-column">
              <div class="mega-column-header">
                <span class="mega-column-icon">💼</span>
                <div>
                  <p class="mega-column-title">Business Management</p>
                  <p class="mega-column-sub">Control money, paperwork &amp; reporting.</p>
                </div>
              </div>
              <ul class="mega-links">
                <li>
                  <a href="/payment">
                    <span class="mega-link-title">Payments</span>
                    <span class="mega-link-text">Make it easy to get paid on time.</span>
                  </a>
                </li>
                <li>
                  <a href="/invoicing">
                    <span class="mega-link-title">Invoicing</span>
                    <span class="mega-link-text">Automatic invoicing &amp; cashflow visibility.</span>
                  </a>
                </li>
                <li>
                  <a href="/expenses">
                    <span class="mega-link-title">Expenses</span>
                    <span class="mega-link-text">Keep your records accurate &amp; compliant.</span>
                  </a>
                </li>
                <li>
                  <a href="/bookkeeping">
                    <span class="mega-link-title">Financials &amp; Reporting</span>
                    <span class="mega-link-text">Understand revenue, profit &amp; performance.</span>
                  </a>
                </li>
              </ul>
            </div>

            <!-- Column 3 -->
            <div class="mega-column">
              <div class="mega-column-header">
                <span class="mega-column-icon">📋</span>
                <div>
                  <p class="mega-column-title">Job Management</p>
                  <p class="mega-column-sub">Stay on top of every job and team member.</p>
                </div>
              </div>
              <ul class="mega-links">
                <li>
                  <a href="/customer_management">
                    <span class="mega-link-title">Customer Management</span>
                    <span class="mega-link-text">Keep relationships organised and updated.</span>
                  </a>
                </li>
                <li>
                  <a href="/jobs">
                    <span class="mega-link-title">Add &amp; Edit Jobs</span>
                    <span class="mega-link-text">Manage tasks, edit details, track progress.</span>
                  </a>
                </li>
                <li>
                  <a href="/assignment_scheduling">
                    <span class="mega-link-title">Work Assignment &amp; Scheduling</span>
                    <span class="mega-link-text">Assign jobs, shifts and plan your week.</span>
                  </a>
                </li>
                <li>
                  <a href="/job_records">
                    <span class="mega-link-title">Job Records &amp; Tracking</span>
                    <span class="mega-link-text">Capture and store every job detail.</span>
                  </a>
                </li>
              </ul>
            </div>
          </div>
        </div><!-- /.mega-menu -->
      </div><!-- /.nav-item.has-mega -->

      <a href="/pricing" data-turbo="false">Pricing</a>

      <!-- Industries dropdown (desktop) -->
      <div class="nav-item has-industries">
        <a href="#industries" class="nav-link">Industries</a>

        <div class="industries-menu">
          <div class="industries-inner">
            <div class="industries-header">
              <p class="industries-eyebrow">Industries</p>
              <p class="industries-sub">
                Join thousands of <%= ENV['WEBSITE_NAME'] %> users across the world from all kinds of service businesses.
              </p>
            </div>

            <ul class="industries-list">
              <li>
                <a href="/professional_window_cleaner_software">
                  <span>Window Cleaning</span>
                  <span class="industries-chevron">›</span>
                </a>
              </li>
              <li>
                <a href="/bin_cleaning_software">
                  <span>Bin Cleaning</span>
                  <span class="industries-chevron">›</span>
                </a>
              </li>
              <li>
                <a href="/carpet_cleaning_software">
                  <span>Carpet Cleaning</span>
                  <span class="industries-chevron">›</span>
                </a>
              </li>
              <li>
                <a href="/exterior_cleaning">
                  <span>Exterior Cleaning</span>
                  <span class="industries-chevron">›</span>
                </a>
              </li>
              <li>
                <a href="/cleaning_housekeeping_maid_service_software">
                  <span>Professional Cleaning</span>
                  <span class="industries-chevron">›</span>
                </a>
              </li>
              <li>
                <a href="/mobile_cleaning_services">
                  <span>Mobile Cleaning Services</span>
                  <span class="industries-chevron">›</span>
                </a>
              </li>
              <li>
                <a href="/other_services">
                  <span>Other Services</span>
                  <span class="industries-chevron">›</span>
                </a>
              </li>
            </ul>
          </div>
        </div><!-- /.industries-menu -->
      </div><!-- /.nav-item.has-industries -->

      <a href="/blog">News &amp; Updates</a>
    </nav>

    <div class="auth">
      <a class="btn btn-outline" href="/users/sign_in">Sign In</a>
      <a class="btn btn-primary1" href="/users/sign_up">Sign Up</a>
    </div>
  </div>

  <!-- Mobile menu drawer -->
  <nav id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <div class="backdrop" data-close></div>
    <div class="panel">
      <div class="panel-header">
        <%= image_tag ENV['LOGO_NAME'], alt: ENV['WEBSITE_NAME'], class: "logo small" %>
        <button class="close" aria-label="Close menu" data-close>&times;</button>
      </div>

      <!-- Features accordion -->
      <div class="mobile-accordion">
        <button class="mobile-accordion-trigger">
          Features
          <span class="chevron">›</span>
        </button>

        <div class="mobile-accordion-panel">
          <p class="mobile-accordion-heading">Customer Services</p>
          <a href="/custom_portal">Customer Portal</a>
          <a href="/customer_messaging">Customer Messaging</a>
          <a href="/marketing_tools">Marketing Tools</a>
          <a href="/marketing_messaging">Marketing Messaging</a>

          <p class="mobile-accordion-heading">Business Management</p>
          <a href="/payment">Payments</a>
          <a href="/invoicing">Invoicing</a>
          <a href="/expenses">Expenses</a>
          <a href="/bookkeeping">Financials &amp; Reporting</a>

          <p class="mobile-accordion-heading">Job Management</p>
          <a href="/customer_management">Customer Management</a>
          <a href="/jobs">Add &amp; Edit Jobs</a>
          <a href="/assignment_scheduling">Work Assignment &amp; Scheduling</a>
          <a href="/job_records">Job Records &amp; Tracking</a>
        </div>
      </div>

      <a href="/pricing" data-close data-turbo="false">Pricing</a>

      <!-- Industries accordion (mobile) -->
      <div class="mobile-accordion">
        <button class="mobile-accordion-trigger">
          Industries
          <span class="chevron">›</span>
        </button>

        <div class="mobile-accordion-panel">
          <a href="/professional_window_cleaner_software">Window Cleaning</a>
          <a href="/bin_cleaning_software">Bin Cleaning</a>
          <a href="/carpet_cleaning_software">Carpet Cleaning</a>
          <a href="/exterior_cleaning">Exterior Cleaning</a>
          <a href="/cleaning_housekeeping_maid_service_software">Professional Cleaning</a>
          <a href="/mobile_cleaning_services">Mobile Cleaning Services</a>
          <a href="/other_services">Other Services</a>
        </div>
      </div>

      <a href="/blog" data-close>News &amp; Updates</a>

      <div class="panel-actions">
        <a class="btn btn-outline" style="color: white;" href="/users/sign_in">Sign In</a>
        <a class="btn btn-primary" href="/users/sign_up">Sign Up</a>
      </div>
    </div>
  </nav>
</header>

<style>
/* Mobile accordion (for Features & Industries inside mobile menu) */
.mobile-accordion {
  width: 100%;
}

.mobile-accordion-trigger {
  width: 100%;
  text-align: left;
  padding: 14px 0;
  border: none;
  background: none;
  font-size: 16px;
  color: #211f54;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mobile-accordion-trigger .chevron {
  transition: transform 0.25s ease;
}

.mobile-accordion.open .chevron {
  transform: rotate(90deg);
}

.mobile-accordion-panel {
  display: none;
  flex-direction: column;
  padding-left: 12px;
  margin-bottom: 12px;
}

.mobile-accordion-panel a {
  padding: 8px 0;
  display: block;
  color: #211f54;
  font-size: 14px;
}

.mobile-accordion-heading {
  margin-top: 12px;
  color: #9ca3af;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* --- Mega menu (desktop Features) --- */

.nav-item.has-mega {
  position: relative;
}

.nav-item.has-mega .mega-menu {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translate(-50%, 10px);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;
  width: 1040px;
  max-width: calc(100vw - 48px);
}

.nav-item.has-mega:hover .mega-menu,
.nav-item.has-mega:focus-within .mega-menu {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translate(-50%, 0);
}

.mega-inner {
  width: 100%;
  border-radius: 16px;
  background: #ffffff;
  box-shadow:
    0 18px 45px rgba(15, 23, 42, 0.18),
    0 0 0 1px rgba(226, 232, 240, 0.9);
  padding: 24px 32px 28px;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 32px;
}

.mega-column {
  min-width: 0;
}

.mega-column-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
}

.mega-column-icon {
  width: 30px;
  height: 30px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #f3f4ff;
  font-size: 16px;
}

.mega-column-title {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #4b5563;
}

.mega-column-sub {
  font-size: 13px;
  color: #9ca3af;
}

.mega-links {
  list-style: none;
  padding: 0;
  margin: 6px 0 0;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.mega-links li a {
  display: block;
  padding: 8px 10px;
  border-radius: 10px;
  text-decoration: none;
  transition: background 0.12s ease, transform 0.12s ease;
}

.mega-link-title {
  display: block;
  font-size: 13px;
  font-weight: 500;
  color: #111827;
}

.mega-link-text {
  display: block;
  font-size: 12px;
  color: #6b7280;
}

.mega-links li a:hover {
  background: #f3f4ff;
  transform: translateX(2px);
}

.mega-links li a::after {
  content: "›";
  float: right;
  font-size: 14px;
  color: #cbd5f5;
  margin-left: 6px;
  transition: transform 0.12s ease, color 0.12s ease;
}

.mega-links li a:hover::after {
  transform: translateX(2px);
  color: #4f46e5;
}

/* --- Industries dropdown (desktop) --- */

.nav-item.has-industries {
  position: relative;
}

.nav-item.has-industries .industries-menu {
  position: absolute;
  top: 100%;
  left: 50%;
  transform: translate(-50%, 10px);
  z-index: 90;
  opacity: 0;
  visibility: hidden;
  pointer-events: none;
  transition: opacity 0.15s ease, transform 0.15s ease, visibility 0.15s ease;
  width: 840px;
  max-width: calc(100vw - 48px);
}

.nav-item.has-industries:hover .industries-menu,
.nav-item.has-industries:focus-within .industries-menu {
  opacity: 1;
  visibility: visible;
  pointer-events: auto;
  transform: translate(-50%, 0);
}

.industries-inner {
  background: #ffffff;
  border-radius: 0 0 16px 16px;
  box-shadow:
    0 18px 45px rgba(15, 23, 42, 0.18),
    0 0 0 1px rgba(226, 232, 240, 0.9);
  padding: 20px 32px 24px;
}

.industries-header {
  margin-bottom: 8px;
}

.industries-eyebrow {
  font-size: 13px;
  color: #6b7280;
  margin-bottom: 4px;
}

.industries-sub {
  font-size: 14px;
  color: #9ca3af;
}

.industries-list {
  list-style: none;
  margin: 16px 0 0;
  padding: 0;
  border-top: 1px solid #e5e7eb;
}

.industries-list li + li {
  border-top: 1px solid #e5e7eb;
}

.industries-list li a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 0;
  text-decoration: none;
  font-size: 15px;
  font-weight: 500;
  color: #111827;
}

.industries-list li a:hover {
  color: #111827;
  background: #f9fafb;
}

.industries-chevron {
  font-size: 16px;
  color: #d1d5db;
}

/* hide dropdowns on small screens (mobile uses slide-out menu) */
@media (max-width: 1000px) {
  .nav-item.has-mega .mega-menu,
  .nav-item.has-industries .industries-menu {
    display: none;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  const triggers = document.querySelectorAll(".mobile-accordion-trigger");

  triggers.forEach(trigger => {
    trigger.addEventListener("click", () => {
      const parent = trigger.parentElement;
      parent.classList.toggle("open");

      const panel = parent.querySelector(".mobile-accordion-panel");
      panel.style.display = parent.classList.contains("open") ? "flex" : "none";
    });
  });
});
</script>
