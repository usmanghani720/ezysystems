<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.4.1/css/responsive.dataTables.min.css">

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.4.1/js/dataTables.responsive.min.js"></script>

<div class="content-wrapper tables-data-page">
  <!-- Content Header -->
  <section class="content-header">
    <h1>Transactions</h1>
    <ol class="breadcrumb">
      <li>
        <%= link_to authenticated_root_path do %>
          <i class="fa fa-dashboard"></i> Home
        <% end %>
      </li>
    </ol>
  </section>

  <!-- Main content -->
  <section class="content">
    <div class="row">
      <div class="col-xs-12">
        <%= render "/layouts/alerts" %>

        <div class="box box-primary">
          <div class="box-header with-border" style="text-align:right;">
            <!-- STATUS FILTERS -->
            <div class="btn-group">
              <% %w[all succeeded failed processing requires_action canceled].each do |s| %>
                <%= link_to s.titleize,
                  connected_payments_path(status: s),
                  class: "btn btn-sm #{(@status == s ? 'btn-primary' : 'btn-default')}" %>
              <% end %>
            </div>
          </div>

          <div class="box-body">
            <table id="payments" class="table table-bordered table-striped responsive nowrap" style="width:100%;">
              <thead>
                <tr>
                  <th>Amount/Currency</th>
                  <th>Customer</th>
                  <th>Status</th>
                  <th>Payment Method</th>
                  <th>Description</th>
                  <th>Date</th>
                  <th>Payment ID</th>
                  <th>Actions</th>
                </tr>
              </thead>

              <tbody>
                <% @rows.each do |row| %>
                  <tr>
                    <td>
                      <strong>
                        $<%= sprintf("%.2f", row[:amount].to_f / 100) %>
                      </strong>
                      <%= row[:currency] %>
                    </td>
                    <td><%= row[:customer] %></td>
                    <td>
                      <span class="label label-<%= row[:status] == 'succeeded' ? 'success' : 'default' %>">
                        <%= row[:status].humanize %>
                        <% if row[:status].humanize == "Requires capture" %>
                          <br />
                          <br />
                          <%= link_to "Capture", capture_ui_path(pi_id: row[:id], customer_id: row[:stripe_account], account: true) %>
                        <% end %>
                      </span>
                    </td>
                    <td><%= row[:payment_method] %></td>
                    <td><%= row[:description] %></td>
                    <td><%= row[:created_at] %></td>
                    <td><%= row[:id] %></td>
                    <td>
                      <% if row[:status] == "succeeded" && row[:charge_id].present? && !row[:refunded] %>
                        <%= button_to "Refund",
                          refund_connected_payment_path(row[:id], stripe_account: row[:stripe_account], status: @status, page: @page, limit: @limit),
                          method: :post,
                          class: "btn btn-xs btn-danger",
                          data: { confirm: "Refund this charge in full? This cannot be undone." } %>
                      <% elsif row[:refunded] %>
                        <span class="label label-default">Refunded</span>
                      <% else %>
                        -
                      <% end %>
                    </td>
                  </tr>
                <% end %>

                <% if @rows.blank? %>
                  <tr>
                    <td colspan="8" class="text-center">
                      No transactions found.
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div><!-- /.box-body -->
        </div><!-- /.box -->

                <!-- SERVER-SIDE PAGINATION (PAGE NUMBERS) -->
        <% if @total_pages.to_i > 1 %>
          <% window = 10 %>
          <% start_page = ((@page - 1) / window) * window + 1 %>
          <% end_page   = [start_page + window - 1, @total_pages].min %>

          <div class="text-center">
            <ul class="pagination">

              <%# Optional: Previous block («) %>
              <% if start_page > 1 %>
                <li>
                  <%= link_to "«",
                    connected_payments_path(
                      page: start_page - 1,
                      limit: @limit,
                      status: @status
                    ) %>
                </li>
              <% end %>

              <%# Optional: Previous page (‹) %>
              <li class="<%= 'disabled' if @page <= 1 %>">
                <% if @page > 1 %>
                  <%= link_to "‹",
                    connected_payments_path(
                      page: @page - 1,
                      limit: @limit,
                      status: @status
                    ) %>
                <% else %>
                  <a href="javascript:void(0)">‹</a>
                <% end %>
              </li>

              <% start_page.upto(end_page) do |p| %>
                <li class="<%= 'active' if p == @page %>">
                  <%= link_to p,
                    connected_payments_path(
                      page: p,
                      limit: @limit,
                      status: @status
                    ) %>
                </li>
              <% end %>

              <%# Optional: Next page (›) %>
              <li class="<%= 'disabled' if @page >= @total_pages %>">
                <% if @page < @total_pages %>
                  <%= link_to "›",
                    connected_payments_path(
                      page: @page + 1,
                      limit: @limit,
                      status: @status
                    ) %>
                <% else %>
                  <a href="javascript:void(0)">›</a>
                <% end %>
              </li>

              <%# Optional: Next block (») %>
              <% if end_page < @total_pages %>
                <li>
                  <%= link_to "»",
                    connected_payments_path(
                      page: end_page + 1,
                      limit: @limit,
                      status: @status
                    ) %>
                </li>
              <% end %>

            </ul>
          </div>
        <% end %>


      </div><!-- /.col -->
    </div><!-- /.row -->
  </section><!-- /.content -->
</div><!-- /.content-wrapper -->

<script>
  $("#payments").DataTable({
    responsive: true,
    paging: false,     // IMPORTANT: Stripe does paging
    searching: false,  // optional
    info: false,       // optional
    order: [[6, "desc"]] // Date column newest first
  });
</script>
