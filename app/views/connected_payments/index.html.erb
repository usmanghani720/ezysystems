<!-- app/views/connected_payments/index.html.erb -->

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
<link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.4.1/css/responsive.dataTables.min.css">

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
<script src="https://cdn.datatables.net/responsive/2.4.1/js/dataTables.responsive.min.js"></script>

<div class="content-wrapper">
  <section class="content-header">
    <h1>Payments</h1>
  </section>

  <section class="content">
    <%= render "/layouts/alerts" %>

    <!-- STATUS TABS -->
    <div class="btn-group mb-3">
      <% %w[all succeeded failed processing requires_action canceled].each do |s| %>
        <%= link_to s.titleize,
          connected_payments_path(status: s),
          class: "btn btn-default #{'btn-primary' if @status == s}" %>
      <% end %>
    </div>

    <table id="payments" class="table table-bordered table-striped">
      <thead>
        <tr>
          <th>Amount</th>
          <th>Currency</th>
          <th>Status</th>
          <th>Payment Method</th>
          <th>Description</th>
          <th>Customer</th>
          <th>Date</th>
          <th>Payment ID</th>
        </tr>
      </thead>
      <tbody>
        <% @rows.each do |r| %>
          <tr>
            <td><strong>$<%= r[:amount] / 100.0 %></strong></td>
            <td><%= r[:currency] %></td>
            <td><%= r[:status] %></td>
            <td><%= r[:payment_method] %></td>
            <td><%= r[:description] %></td>
            <td><%= r[:customer] %></td>
            <td><%= r[:created_at] %></td>
            <td><%= r[:id] %></td>
          </tr>
        <% end %>

        <% if @rows.empty? %>
          <tr>
            <td colspan="8" class="text-center">No payments found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <!-- PAGINATION -->
    <div class="text-center">
      <% if @total_pages > 1 %>
        <ul class="pagination">
          <% 1.upto(@total_pages) do |p| %>
            <li class="<%= 'active' if p == @page %>">
              <%= link_to p,
                connected_payments_path(
                  page: p,
                  limit: @limit,
                  status: @status
                ) %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>
  </section>
</div>


<script>
  $("#payments").DataTable({
    responsive: true,
    paging: false,     // IMPORTANT: Stripe does paging
    searching: false,  // optional
    info: false,       // optional
    order: [[6, "desc"]] // Date column newest first
  });
</script>
