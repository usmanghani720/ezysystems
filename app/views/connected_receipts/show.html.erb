<!DOCTYPE html>
<html>
<head>
  <title>Betalingsbewijs</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      margin: 0;
      padding: 0;
      background-color: #fafafa;
      color: #1a1f36;
    }
    .main-content {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 20px;
    }
    .logo {
      text-align: center;
      margin-bottom: 30px;
    }
    .logo img {
      height: 40px;
    }
    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
    }
    .header h1 {
      font-size: 24px;
      font-weight: 600;
      margin: 0;
    }
    .header .status {
      display: inline-flex;
      align-items: center;
      background-color: #e7f7e9;
      color: #28a745;
      padding: 5px 10px;
      border-radius: 12px;
      font-size: 14px;
      font-weight: 500;
    }
    .header .status::before {
      content: "✓";
      margin-right: 5px;
    }
    .section {
      background-color: #fff;
      border: 1px solid #e6e8eb;
      border-radius: 8px;
      padding: 20px;
      margin-bottom: 20px;
    }
    .section h2 {
      font-size: 16px;
      font-weight: 600;
      margin: 0 0 20px;
      color: #1a1f36;
    }
    .section p {
      margin: 10px 0;
      font-size: 14px;
      color: #1a1f36;
    }
    .section p strong {
      display: inline-block;
      width: 200px;
      font-weight: 500;
    }
    .footer {
      text-align: center;
      margin-top: 20px;
      font-size: 14px;
      color: #8898aa;
    }
    .footer a {
      color: #635bff;
      text-decoration: none;
    }
    .footer a:hover {
      text-decoration: underline;
    }
  </style>
</head>
<body>
  <div class="main-content">
    <!-- Stripe Logo -->
    <div class="logo">
    </div>

    <!-- Header -->
    <div class="header">
      <h1>Betalingsbewijs voor Gekoppelde Account</h1>
      <span class="status">Geslaagd</span>
    </div>

    <!-- Details Section -->
    <div class="section">
      <h2>Details</h2>
      <p><strong>Betalingsdatum:</strong> <%= Time.at(@payment_intent.created).strftime('%d %B %Y') %></p>
      <p><strong>Totaal Betaald Bedrag:</strong> <%= format_amount(@payment_intent.amount, @payment_intent.currency) %></p>
      <p><strong>Aanvraagkosten:</strong> <%= format_amount(@payment_intent.application_fee_amount, @payment_intent.currency) %></p>
      <p><strong>Bedrag Overgemaakt aan U:</strong> <%= @transfer_amount.round(2) %> <%= @payment_intent.currency.upcase %></p>
      <p><strong>E-mailadres:</strong> <%= current_user.email %></p>
    </div>

    <!-- Footer -->
    <div class="footer">
      <p>Bedankt voor de samenwerking! 🚀</p>
      <a href="https://www.appointmentssetter.nl" target="_blank">Team AppointmentsSetter.nl</a>
    </div>
  </div>
</body>
</html>